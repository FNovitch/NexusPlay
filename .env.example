# Backend
NODE_ENV=development
PORT=4000
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/nexusplay?schema=public"
JWT_SECRET="YOUR_LONG_RANDOM_SECRET_WITH_AT_LEAST_32_CHARACTERS"
JWT_EXPIRES_IN="7d"
FRONTEND_URL="http://localhost:5173"
BACKEND_URL="http://localhost:4000"

# NexusPlay deve usar URL, banco e secrets proprios. Nao reutilize variaveis do projeto antigo.

# Mercado Pago
MERCADO_PAGO_ACCESS_TOKEN=""
MERCADO_PAGO_PUBLIC_KEY=""
MERCADO_PAGO_WEBHOOK_SECRET=""

# Email / recuperacao de senha
SMTP_HOST=""
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="NexusPlay <no-reply@example.com>"

# Cloudinary
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_FOLDER="nexusplay/products"

# Melhor Envio
MELHOR_ENVIO_BASE_URL="https://sandbox.melhorenvio.com.br/api"
MELHOR_ENVIO_TOKEN=""
MELHOR_ENVIO_CLIENT_ID=""
MELHOR_ENVIO_CLIENT_SECRET=""
MELHOR_ENVIO_REDIRECT_URL="http://localhost:4000/api/v1/melhor-envio/callback"
MELHOR_ENVIO_SANDBOX=true
MELHOR_ENVIO_USER_AGENT="NexusPlay Marketplace (technical-contact@example.com)"
MELHOR_ENVIO_CEP_ORIGEM="55900000"

# Frontend
VITE_API_URL="http://localhost:4000/api/v1"
VITE_BACKEND_URL="http://localhost:4000"
VITE_MERCADO_PAGO_PUBLIC_KEY=""
VITE_MELHOR_ENVIO_ENABLED=true
