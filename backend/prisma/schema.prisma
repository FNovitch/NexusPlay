generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  CUSTOMER
  ARTISAN
  ADMIN
}

enum UserType {
  CUSTOMER
  ARTISAN
  ADMIN
}

enum AdminPermissionLevel {
  SUPER_ADMIN
  MANAGER
  SUPPORT
}

enum SellerStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  SOLD_OUT
  PENDING
  REJECTED
}

enum OrderStatus {
  CREATED
  PENDING
  AWAITING_PAYMENT
  PAID
  IN_PRODUCTION
  SHIPPED
  DELIVERED
  CANCELED
  PAYMENT_REJECTED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELED
  REFUNDED
}

enum ReviewType {
  PRODUCT
  SELLER
}

enum SubscriptionPlanType {
  MONTHLY
  YEARLY
}

enum ArtisanSubscriptionStatus {
  TRIAL_ACTIVE
  ACTIVE
  EXPIRED
  CANCELED
  PENDING
  REJECTED
}

enum PaymentHistoryType {
  ARTISAN_SUBSCRIPTION
  CUSTOMER_PURCHASE
  ARTISAN_PAYOUT
}

enum SellerPayoutStatus {
  BLOCKED
  AVAILABLE
  PAID
  CANCELED
}

model User {
  id           String     @id @default(uuid())
  name         String
  email        String     @unique
  passwordHash String
  resetPasswordToken String?
  resetPasswordExpires DateTime?
  role         UserRole   @default(CUSTOMER)
  storeId      String?
  isDeleted    Boolean    @default(false)
  avatarUrl    String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  store        Seller?    @relation("UserStore", fields: [storeId], references: [id], onDelete: SetNull)
  seller       Seller?
  customer     Customer?
  artisan      Artisan?
  adminProfile Admin?
  favorites    Favorite[]
  orders       Order[]    @relation("BuyerOrders")
  reviews      Review[]   @relation("AuthorReviews")
  addresses    Address[]

  @@index([role, isDeleted])
  @@index([storeId])
}

model Seller {
  id         String       @id @default(uuid())
  userId     String       @unique
  storeName  String
  slug       String       @unique
  bio        String
  story      String
  avatarUrl  String?
  coverUrl   String?
  status     SellerStatus @default(PENDING)
  rating     Float        @default(0)
  salesCount Int          @default(0)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  storeUsers User[]       @relation("UserStore")
  artisans   Artisan[]    @relation("ArtisanStore")
  products   Product[]
  orderItems OrderItem[]
  reviews    Review[]
}

model Customer {
  id        String    @id @default(uuid())
  userId    String    @unique
  userType  UserType  @default(CUSTOMER)
  name      String
  birthDate DateTime
  cpf       String    @unique
  phone     String
  active    Boolean   @default(true)
  blocked   Boolean   @default(false)
  blockReason String?
  isDeleted Boolean   @default(false)
  storeId   String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  addresses Address[]
  paymentHistories PaymentHistory[]

  @@index([userType, isDeleted])
  @@index([storeId])
}

model Artisan {
  id               String    @id @default(uuid())
  userId           String    @unique
  userType         UserType  @default(ARTISAN)
  name             String
  cpf              String?
  phone            String
  storeId          String?   @unique
  storeName        String
  storeSlug        String    @unique
  storeDescription String
  craftCategories  String[]  @default([])
  document         String    @unique
  acceptsLocalPickup Boolean @default(false)
  pickupInstructions String?
  subscriptionActive Boolean @default(false)
  trialStart       DateTime?
  trialEnd         DateTime?
  subscriptionExpiresAt DateTime?
  status           SellerStatus @default(PENDING)
  active           Boolean   @default(true)
  blocked          Boolean   @default(false)
  rejectionReason  String?
  blockReason      String?
  isDeleted        Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  store            Seller?   @relation("ArtisanStore", fields: [storeId], references: [id], onDelete: SetNull)
  addresses        Address[]
  subscriptions    ArtisanSubscription[]
  paymentHistories PaymentHistory[]
  sellerPayouts    SellerPayout[]
  shippingQuotes   OrderShipping[]

  @@index([userType, isDeleted])
  @@index([storeId])
}

model Admin {
  id              String               @id @default(uuid())
  userId          String               @unique
  userType        UserType             @default(ADMIN)
  name            String
  permissionLevel AdminPermissionLevel
  active          Boolean              @default(true)
  isDeleted       Boolean              @default(false)
  lastLogin       DateTime?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userType, isDeleted])
  @@index([permissionLevel])
}

model Address {
  id           String    @id @default(uuid())
  userId       String
  customerId   String?
  artisanId    String?
  street       String
  number       String
  complement   String?
  neighborhood String
  city         String
  state        String
  zipCode      String
  country      String    @default("BR")
  isDefault    Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  customer     Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  artisan      Artisan?  @relation(fields: [artisanId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([customerId])
  @@index([artisanId])
  @@index([zipCode])
}

model Category {
  id          String    @id @default(uuid())
  name        String
  slug        String    @unique
  description String?
  imageUrl    String?
  active      Boolean   @default(true)
  products    Product[]
}

model SubscriptionPlan {
  id          String               @id @default(uuid())
  name        String
  description String?
  price       Decimal              @db.Decimal(10, 2)
  durationDays Int
  type        SubscriptionPlanType
  active      Boolean              @default(true)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  subscriptions ArtisanSubscription[]

  @@unique([type])
}

model ArtisanSubscription {
  id          String                    @id @default(uuid())
  artisanId   String
  planId      String?
  status      ArtisanSubscriptionStatus @default(PENDING)
  trialStart  DateTime?
  trialEnd    DateTime?
  startDate   DateTime?
  expirationDate DateTime?
  mpPreferenceId String?
  mpPaymentId    String?
  mpStatus       String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  artisan        Artisan               @relation(fields: [artisanId], references: [id], onDelete: Cascade)
  plan           SubscriptionPlan?      @relation(fields: [planId], references: [id], onDelete: SetNull)
  paymentHistories PaymentHistory[]

  @@index([artisanId])
  @@index([status])
  @@index([expirationDate])
}

model Product {
  id                     String        @id @default(uuid())
  sellerId               String
  categoryId             String
  name                   String
  slug                   String        @unique
  description            String
  price                  Decimal       @db.Decimal(10, 2)
  stock                  Int
  categoryName           String        @default("")
  images                 Json          @default("[]")
  mainImage              Json?
  artisanId              String        @default("")
  artisanName            String        @default("")
  artisanSlug            String        @default("")
  dimensions             Json?
  variations             Json          @default("[]")
  weight                 Decimal       @default(0) @db.Decimal(10, 3)
  shippingAvailable      Boolean       @default(true)
  pickupAvailable        Boolean       @default(false)
  pickupAddress          String?
  customizationAvailable Boolean       @default(false)
  personalizationPrompt  String?
  status                 ProductStatus @default(PENDING)
  rejectionReason        String?
  averageRating          Float         @default(0)
  totalReviews           Int           @default(0)
  rating                 Float         @default(0)
  salesCount             Int           @default(0)
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  seller                 Seller        @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  category               Category      @relation(fields: [categoryId], references: [id])
  productImages          ProductImage[]
  favorites              Favorite[]
  orderItems             OrderItem[]
  reviews                Review[]

  @@unique([sellerId, slug])
  @@index([name])
  @@index([artisanId])
  @@index([artisanSlug])
  @@index([categoryName])
  @@index([status, averageRating])
  @@index([status, rating])
}

model ProductImage {
  id        String   @id @default(uuid())
  productId String
  url       String
  publicId  String   @unique
  fileName  String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Favorite {
  userId    String
  productId String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([userId, productId])
}

model Order {
  id             String        @id @default(uuid())
  orderCode      String        @unique @default(uuid())
  buyerId        String
  status         OrderStatus   @default(CREATED)
  paymentStatus  PaymentStatus @default(PENDING)
  paymentMethod  String?
  productsTotal  Decimal       @default(0) @db.Decimal(10, 2)
  shippingTotal  Decimal       @default(0) @db.Decimal(10, 2)
  total          Decimal       @db.Decimal(10, 2)
  shippingAddress Json?
  mpPreferenceId String?
  mpPaymentId    String?
  mpStatus       String?
  paymentReleasedToArtisan Boolean @default(false)
  customerConfirmedDelivery Boolean @default(false)
  deliveryConfirmedAt DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  buyer          User          @relation("BuyerOrders", fields: [buyerId], references: [id])
  items          OrderItem[]
  history        OrderHistory[]
  paymentHistories PaymentHistory[]
  sellerPayouts    SellerPayout[]
  shippingQuotes   OrderShipping[]
}

model OrderShipping {
  id                 String   @id @default(uuid())
  orderId            String
  artisanId          String?
  sellerId           String?
  originZipCode      String
  destinationZipCode String
  carrier            String
  service            String
  serviceId          String
  price              Decimal  @db.Decimal(10, 2)
  deliveryTime       Int
  melhorEnvioId      String?
  status             String   @default("QUOTED")
  trackingCode       String?
  labelUrl           String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  order              Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  artisan            Artisan? @relation(fields: [artisanId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([artisanId])
  @@index([sellerId])
  @@index([status])
}

model OrderItem {
  id                 String  @id @default(uuid())
  orderId            String
  productId          String
  sellerId           String
  productName        String  @default("")
  productImage       String?
  quantity           Int
  unitPrice          Decimal @db.Decimal(10, 2)
  total              Decimal @db.Decimal(10, 2)
  customizationNotes String?
  selectedVariations Json?
  order              Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product            Product @relation(fields: [productId], references: [id])
  seller             Seller  @relation(fields: [sellerId], references: [id])
  review             Review?
}

model OrderHistory {
  id             String      @id @default(uuid())
  orderId        String
  previousStatus OrderStatus?
  newStatus      OrderStatus
  note           String?
  createdAt      DateTime    @default(now())
  order          Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model Review {
  id          String     @id @default(uuid())
  authorId    String
  productId   String?
  sellerId    String?
  orderItemId String?    @unique
  type        ReviewType
  rating      Int
  comment     String
  hidden      Boolean    @default(false)
  createdAt   DateTime   @default(now())
  author      User       @relation("AuthorReviews", fields: [authorId], references: [id], onDelete: Cascade)
  product     Product?   @relation(fields: [productId], references: [id], onDelete: Cascade)
  seller      Seller?    @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  orderItem   OrderItem? @relation(fields: [orderItemId], references: [id])
}

model PaymentHistory {
  id          String             @id @default(uuid())
  artisanId   String?
  customerId  String?
  orderId     String?
  subscriptionId String?
  type        PaymentHistoryType
  amount      Decimal            @db.Decimal(10, 2)
  status      String
  mpPaymentId String?
  mpPreferenceId String?
  description String?
  createdAt   DateTime           @default(now())
  artisan      Artisan?           @relation(fields: [artisanId], references: [id], onDelete: SetNull)
  customer     Customer?          @relation(fields: [customerId], references: [id], onDelete: SetNull)
  order        Order?             @relation(fields: [orderId], references: [id], onDelete: SetNull)
  subscription ArtisanSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([artisanId])
  @@index([customerId])
  @@index([orderId])
  @@index([subscriptionId])
  @@index([type])
}

model SellerPayout {
  id          String             @id @default(uuid())
  orderId     String
  artisanId   String
  saleAmount  Decimal            @db.Decimal(10, 2)
  shippingAmount Decimal         @default(0) @db.Decimal(10, 2)
  totalAmount Decimal            @db.Decimal(10, 2)
  availableAmount Decimal        @db.Decimal(10, 2)
  status      SellerPayoutStatus @default(BLOCKED)
  releasedAt  DateTime?
  paidAt      DateTime?
  note        String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  order       Order              @relation(fields: [orderId], references: [id], onDelete: Cascade)
  artisan     Artisan            @relation(fields: [artisanId], references: [id], onDelete: Cascade)

  @@unique([orderId, artisanId])
  @@index([artisanId])
  @@index([status])
}

model Coupon {
  id         String    @id @default(uuid())
  code       String    @unique
  percentOff Int
  active     Boolean   @default(true)
  expiresAt  DateTime?
}
